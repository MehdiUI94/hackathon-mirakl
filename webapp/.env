# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="file:./dev.db"

# Free deployment target:
# - Vercel Hobby for the app
# - Neon Free for PostgreSQL
#
# Copy the real values from Neon before running the app in PostgreSQL mode.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/DB?sslmode=require&pgbouncer=true"
# DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# Public URL used by n8n Cloud to call this app back.
# Leave empty locally until you have a real stable URL.
N8N_CALLBACK_BASE_URL=""

# Public URL of the app (used for absolute links and API callbacks).
APP_BASE_URL=""

# Stable Cloudflare named tunnel support.
CLOUDFLARE_TUNNEL_NAME=""
CLOUDFLARE_TUNNEL_HOSTNAME=""

# Optional fallback if Settings > n8nWebhookUrl is empty.
N8N_LAUNCH_WEBHOOK_URL="https://jbuyikana.app.n8n.cloud/webhook/a00ddf8f-cb36-4e98-a638-08a90ad8a00c"

# Default sender fallback used by the app when Settings persistence is unavailable.
DEFAULT_SENDER_EMAIL="mzitouni@eugeniaschool.com"
DEFAULT_SENDER_NAME="Mehdi"

# Direct email delivery via SMTP.
# Replace these placeholders with your real SMTP credentials.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="zitounimehdi7@gmail.com"
