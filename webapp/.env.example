DATABASE_URL="file:./dev.db"

# n8n -> app callback base URL.
# For a temporary quick tunnel:
# N8N_CALLBACK_BASE_URL="https://xxxx.trycloudflare.com"
#
# For a stable named tunnel or real deployment:
# N8N_CALLBACK_BASE_URL="https://preview.example.com"
APP_BASE_URL=""
N8N_CALLBACK_BASE_URL=""

# Optional fallback if Settings > n8nWebhookUrl is empty.
N8N_LAUNCH_WEBHOOK_URL=""
DEFAULT_SENDER_EMAIL=""
DEFAULT_SENDER_NAME=""

# Direct email delivery via SMTP.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_EMAIL=""
SMTP_FROM_NAME=""

# Stable Cloudflare named tunnel support.
# Requires a real Cloudflare account + tunnel already created.
CLOUDFLARE_TUNNEL_NAME=""
CLOUDFLARE_TUNNEL_HOSTNAME=""
